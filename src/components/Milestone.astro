---
// src/components/Milestone.astro
const experiences = [
  {
    year: "2026 - Current",
    title: "Internship in IT department of government agency",
    company: "Indonesian Education University (UPI)",
    desc: "Learn current technologies, workflows and industry Practices."
  },
  {
    year: "2025",
    title: "IT Student & Hobbyist",
    company: "Vocational High School",
    desc: "Focus on deepening software engineering, basic algorithms, containerization experiments (Docker), and exploring the aesthetic harmony of modern interfaces & tools."
  }
];
---

<section id="experience" class="relative snap-start min-h-[100dvh] flex flex-col justify-center items-center overflow-hidden bg-tan dark:bg-dark text-dark dark:text-tan transition-colors duration-300 px-6 py-12">
  
  <canvas id="mesh-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-10"></canvas>
  
  <div class="absolute inset-0 bg-gradient-to-t from-tan via-transparent to-tan/50 dark:from-dark dark:via-transparent dark:to-dark/50 z-10 pointer-events-none"></div>

  <div class="text-center mb-15 relative z-20">
    <span class="font-mark-script text-2xl text-purple-600 dark:text-purple-400 tracking-wide block mb-2">Journey</span>
    <h2 class="text-3xl sm:text-5xl font-black tracking-tight bg-gradient-to-r from-zinc-900 via-zinc-700 to-zinc-500 dark:from-white dark:via-zinc-200 dark:to-zinc-400 bg-clip-text text-transparent">
      Milestones & Experience
    </h2>
  </div>

  <div class="relative z-20 w-full max-w-3xl flex flex-col items-center justify-center">
    
    <button id="scroll-up-btn" class="absolute -top-12 p-2 rounded-full border border-zinc-300 dark:border-zinc-800 bg-white/80 dark:bg-zinc-900/80 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition shadow-sm z-30 opacity-30 pointer-events-none" aria-label="Scroll Up">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
      </svg>
    </button>

    <div id="timeline-scroll-area" class="relative w-full max-h-[55dvh] overflow-y-auto pr-2 scroll-smooth space-y-6 min-h-[320px]">
      
      {experiences.map((exp, index) => {
        const isEven = index % 2 === 0;
        return (
          /* STRUKTUR GRID PINTAR:
            - Mobile: 2 Kolom -> Lebar tetap 32px (untuk icon/line) dan sisanya 1fr (untuk card)
            - Desktop (sm): 3 Kolom -> Rata seimbang 1fr, auto (tengah), 1fr
          */
          <div class="milestone-item relative grid grid-cols-[32px_1fr] sm:grid-cols-[1fr_auto_1fr] gap-x-4 sm:gap-x-8 items-start w-full z-10 transition-all duration-700 opacity-30 transform translate-y-4">
            
            <div class={`w-full p-5 rounded-2xl bg-white/60 dark:bg-zinc-900/40 border border-zinc-200/60 dark:border-zinc-800/60 backdrop-blur-md shadow-sm hover:border-purple-500/50 dark:hover:border-purple-400/50 transition duration-300 col-start-2 ${isEven ? 'sm:col-start-1' : 'sm:col-start-3'}`}>
              <span class="text-xs font-bold text-purple-600 dark:text-purple-400 uppercase tracking-widest">{exp.year}</span>
              <h3 class="text-lg font-bold text-zinc-900 dark:text-white mt-1">{exp.title}</h3>
              <h4 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-2">{exp.company}</h4>
              <p class="text-xs sm:text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{exp.desc}</p>
            </div>

            <div class={`col-start-1 row-start-1 sm:col-start-2 flex flex-col items-center justify-start h-full relative min-w-[32px] sm:min-w-[40px]`}>
              <div class={`w-[2px] bg-zinc-300 dark:bg-zinc-800 absolute left-1/2 transform -translate-x-1/2 z-0 
                ${index === 0 ? 'top-7 bottom-0' : ''} 
                ${index === experiences.length - 1 ? 'top-0 h-7 bottom-auto' : ''} 
                ${index > 0 && index < experiences.length - 1 ? 'top-0 bottom-0' : ''}
              `}></div>
              
              <div class="w-3 h-3 rounded-full border-2 border-purple-500 bg-tan dark:bg-dark z-20 shadow-sm mt-7 timeline-dot transition-all duration-300"></div>
            </div>

            <div class={`hidden sm:block row-start-1 ${isEven ? 'sm:col-start-3' : 'sm:col-start-1'}`}></div>

          </div>
        )
      })}

    </div>

    <button id="scroll-down-btn" class="absolute -bottom-12 p-2 rounded-full border border-zinc-300 dark:border-zinc-800 bg-white/80 dark:bg-zinc-900/80 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition shadow-sm z-30" aria-label="Scroll Down">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </button>

  </div>
</section>

<style>
  #timeline-scroll-area {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  #timeline-scroll-area::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initMilestone() {
    // === 1. LOGIKA UTAMA SCROLL INTERNAL ===
    const scrollArea = document.getElementById('timeline-scroll-area');
    const upBtn = document.getElementById('scroll-up-btn');
    const downBtn = document.getElementById('scroll-down-btn');
    const items = document.querySelectorAll('.milestone-item');

    if (scrollArea && upBtn && downBtn) {
      const scrollAmount = 180;

      upBtn.addEventListener('click', () => {
        scrollArea.scrollBy({ top: -scrollAmount, behavior: 'smooth' });
      });

      downBtn.addEventListener('click', () => {
        scrollArea.scrollBy({ top: scrollAmount, behavior: 'smooth' });
      });

      scrollArea.addEventListener('scroll', () => {
        const scrollTop = scrollArea.scrollTop;
        const scrollHeight = scrollArea.scrollHeight;
        const clientHeight = scrollArea.clientHeight;

        if (scrollTop <= 5) {
          upBtn.classList.add('opacity-30', 'pointer-events-none');
        } else {
          upBtn.classList.remove('opacity-30', 'pointer-events-none');
        }

        if (scrollTop + clientHeight >= scrollHeight - 5) {
          downBtn.classList.add('opacity-30', 'pointer-events-none');
        } else {
          downBtn.classList.remove('opacity-30', 'pointer-events-none');
        }

        revealOnScrollInternal();
      });

      function revealOnScrollInternal() {
        items.forEach((item) => {
          const itemTop = item.getBoundingClientRect().top;
          const containerTop = scrollArea!.getBoundingClientRect().top;
          const containerBottom = containerTop + scrollArea!.clientHeight;

          if (itemTop >= containerTop - 20 && itemTop <= containerBottom - 80) {
            item.classList.remove('opacity-30', 'translate-y-4');
            item.classList.add('opacity-100', 'translate-y-0');
            const dot = item.querySelector('.timeline-dot');
            if (dot) dot.classList.add('scale-150', 'bg-purple-500');
          } else {
            item.classList.remove('opacity-100', 'translate-y-0');
            item.classList.add('opacity-30', 'translate-y-4');
            const dot = item.querySelector('.timeline-dot');
            if (dot) dot.classList.remove('scale-150', 'bg-purple-500');
          }
        });
      }
      setTimeout(revealOnScrollInternal, 100);
    }

    // === 2. INTERACTIVE RED CONSTELLATION CANVAS ===
    const canvas = document.getElementById('mesh-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = (canvas.width = window.innerWidth);
    let height = (canvas.height = window.innerHeight);

    let mouse = {
      x: null as number | null,
      y: null as number | null,
      max: 180
    };

    const section = document.getElementById('experience');
    if (section) {
      section.addEventListener('mousemove', (e) => {
        const rect = section.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });

      section.addEventListener('mouseleave', () => {
        mouse.x = null;
        mouse.y = null;
      });
    }

    class Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      radius: number;

      constructor() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.vx = (Math.random() - 0.5) * 0.8;
        this.vy = (Math.random() - 0.5) * 0.8;
        this.radius = Math.random() * 2 + 1;
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;

        if (this.x < 0 || this.x > width) this.vx *= -1;
        if (this.y < 0 || this.y > height) this.vy *= -1;

        if (mouse.x !== null && mouse.y !== null) {
          const dx = this.x - mouse.x;
          const dy = this.y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < mouse.max) {
            this.x -= dx * 0.03;
            this.y -= dy * 0.03;
          }
        }
      }

      draw() {
        ctx!.fillStyle = 'rgba(239, 68, 68, 0.75)';
        ctx!.beginPath();
        ctx!.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    const particleDensity = window.innerWidth < 640 ? 30 : 75;
    const particles: Particle[] = [];
    for (let i = 0; i < particleDensity; i++) {
      particles.push(new Particle());
    }

    function animateMesh() {
      const isDark = document.documentElement.classList.contains('dark') || document.body.classList.contains('dark');
      
      ctx!.fillStyle = isDark ? '#1a1a1a' : '#edeadf';
      ctx!.fillRect(0, 0, width, height);

      particles.forEach(p => {
        p.update();
        p.draw();
      });

      const lineMaxDist = 140;
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < lineMaxDist) {
            const alpha = (1 - dist / lineMaxDist) * 0.22;
            ctx!.strokeStyle = `rgba(239, 68, 68, ${alpha})`;
            ctx!.lineWidth = 0.9;
            ctx!.beginPath();
            ctx!.moveTo(particles[i].x, particles[i].y);
            ctx!.lineTo(particles[j].x, particles[j].y);
            ctx!.stroke();
          }
        }

        if (mouse.x !== null && mouse.y !== null) {
          const dx = particles[i].x - mouse.x;
          const dy = particles[i].y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < mouse.max) {
            const alpha = (1 - dist / mouse.max) * 0.28;
            ctx!.strokeStyle = `rgba(239, 68, 68, ${alpha})`;
            ctx!.lineWidth = 1.1;
            ctx!.beginPath();
            ctx!.moveTo(particles[i].x, particles[i].y);
            ctx!.lineTo(mouse.x, mouse.y);
            ctx!.stroke();
          }
        }
      }

      requestAnimationFrame(animateMesh);
    }

    window.addEventListener('resize', () => {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
    });

    animateMesh();
  }

  document.addEventListener('astro:page-load', initMilestone);
  initMilestone();
</script>
