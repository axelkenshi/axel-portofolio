        <img src="/img/techstack/php.svg" alt="php" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/mysql.svg" alt="mysql" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/tailwind.svg" alt="Tailwind" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/bootstrap.svg" alt="bootstrap" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/astro.svg" alt="Astro" class="h-8 w-auto opacity-75 grayscale dark:invert dark:hover:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/svelte.svg" alt="Svelte" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/nodejs.svg" alt="NodeJS" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <!-- tools img -->
        <img src="/img/techstack/vite-tool.svg" alt="vite" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/firebase-tool.svg" alt="firebase" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/zed-tool.svg" alt="zed" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/gemini-tool.svg" alt="gemini" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/claude-tool.svg" alt="claude" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
      </div>

      <!-- Set Kedua Duplikasi Ikon SVG (Wajib Sama Persis untuk Loop Mulus) -->
      <div class="flex gap-16 items-center shrink-0">
        <!-- lang img -->
        <img src="/img/techstack/html.svg" alt="HTML5" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/css.svg" alt="CSS3" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/js.svg" alt="JavaScript" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/ts.svg" alt="TypeScript" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/php.svg" alt="php" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/mysql.svg" alt="mysql" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/tailwind.svg" alt="Tailwind" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/bootstrap.svg" alt="bootstrap" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/astro.svg" alt="Astro" class="h-8 w-auto opacity-75 grayscale dark:invert dark:hover:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/svelte.svg" alt="Svelte" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/nodejs.svg" alt="NodeJS" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <!-- tools img -->
        <img src="/img/techstack/vite-tool.svg" alt="vite" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/firebase-tool.svg" alt="firebase" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/zed-tool.svg" alt="zed" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/gemini-tool.svg" alt="gemini" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
        <img src="/img/techstack/claude-tool.svg" alt="claude" class="h-8 w-auto opacity-75 grayscale dark:invert-0 hover:grayscale-0 dark:hover:opacity-100 transition duration-300" />
      </div>

    </div>
  </div>

</section>

<!-- 4. GAYA ANIMASI RUNNING TEXT (Scoped CSS) -->
<style>
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(calc(-50% - 32px)); } /* Kompensasi gap pembungkus luar */
  }
  .animate-marquee {
    animation: marquee 25s linear infinite;
  }
  /* Menghentikan jalan teks saat di-hover kursor */
  .animate-marquee:hover {
    animation-play-state: paused;
  }
</style>

<!-- 5. ANIMASI CANVAS PIPELINE (Responsive & Adaptif Skema Tema) -->
<script>
  function initPipeline() {
    const canvas = document.getElementById('pipeline-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = (canvas.width = window.innerWidth);
    let height = (canvas.height = window.innerHeight);

    const spacing = 40;
    const speed = 1.5;
    
    // Warna Pipa adaptif dual-tema
    const colors = ['#0891b2', '#7c3aed', '#4f46e5', '#059669']; 
    
    class Pipe {
      x: number;
      y: number;
      dir: number;
      color: string;

      constructor() {
        this.x = Math.floor(Math.random() * (width / spacing)) * spacing;
        this.y = Math.floor(Math.random() * (height / spacing)) * spacing;
        this.dir = Math.floor(Math.random() * 4);
        this.color = colors[Math.floor(Math.random() * colors.length)];
      }

      update() {
        if (this.dir === 0) this.y -= speed;
        else if (this.dir === 1) this.x += speed;
        else if (this.dir === 2) this.y += speed;
        else if (this.dir === 3) this.x -= speed;

        if (Math.floor(this.x) % spacing === 0 && Math.floor(this.y) % spacing === 0) {
          if (Math.random() < 0.25) {
            const currentDir = this.dir;
            while (this.dir === currentDir || Math.abs(this.dir - currentDir) === 2) {
              this.dir = Math.floor(Math.random() * 4);
            }
          }
        }

        if (this.x < -100 || this.x > width + 100 || this.y < -100 || this.y > height + 100) {
          this.x = Math.floor(Math.random() * (width / spacing)) * spacing;
          this.y = Math.floor(Math.random() * (height / spacing)) * spacing;
          this.dir = Math.floor(Math.random() * 4);
        }
      }

      draw() {
        ctx!.fillStyle = this.color;
        ctx!.beginPath();
        ctx!.arc(this.x, this.y, 1.2, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    const maxPipes = 20;
    const pipes: Pipe[] = [];
    for (let i = 0; i < maxPipes; i++) {
      pipes.push(new Pipe());
    }

    function animate() {
      // Deteksi kelas tema aktif (dark / light)
      const isDark = document.documentElement.classList.contains('dark') || document.body.classList.contains('dark');
      
      // Jika dark gunakan variabel --color-dark (#1a1a1a), jika light gunakan --color-tan (#edeadf) dengan alpha transparan
      ctx!.fillStyle = isDark ? 'rgba(26, 26, 26, 0.05)' : 'rgba(237, 234, 223, 0.05)';
      ctx!.fillRect(0, 0, width, height);

      pipes.forEach((pipe) => {
        pipe.update();
        pipe.draw();
      });

      requestAnimationFrame(animate);
    }

    window.addEventListener('resize', () => {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
    });

    animate();
  }

  // Integrasi mulus untuk transisi halaman Astro View Transitions
  document.addEventListener('astro:page-load', initPipeline);
  initPipeline();
</script>
