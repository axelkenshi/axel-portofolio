---
import "../styles/global.css";
import Navbar from "../components/Navbar.svelte";
import ThemeInit from "../components/ThemeInit.astro";
import { ClientRouter } from "astro:transitions";

// Mendefinisikan tipe data untuk properti (props) yang bisa diterima layout
interface Props {
  title: string;
  description?: string;
}

// Menangkap data title dan description yang dikirim oleh halaman penyeru
const { title, description = "Portfolio & Personal Notes" } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- SEO Meta Tags Dinamis -->
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- FOUC prevention -->
    <ThemeInit />
    <!-- Client-side navigation antar halaman (eliminasi full page reload) -->
    <ClientRouter />
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased">
    
    <!-- 1. NAVBAR GLOBAL: Otomatis ada di setiap halaman -->
   	<Navbar client:idle transition:persist="navbar" />

    <!-- 2. SLOT KONTEN: Tempat masuknya kode unik dari file halaman Anda -->
    <slot />

    <!-- 3. FOOTER GLOBAL: Bagian bawah yang konsisten di seluruh sub-page -->
    <footer class="text-center text-xs text-zinc-500 py-6 border-t border-zinc-900 bg-zinc-950">
      &copy; {new Date().getFullYear()} Axel Kenshi. Built with Astro & Svelte.
    </footer>

  </body>
</html>
