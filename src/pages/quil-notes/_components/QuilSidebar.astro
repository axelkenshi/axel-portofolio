---
// src/pages/quil-notes/_components/QuilSidebar.astro
import { getCollection } from 'astro:content';

// 1. Tarik semua catatan yang terdaftar di Content Layer API
const allNotes = await getCollection('notes');

// 2. Kalkulasi Data Kategori Dinamis
const categoryMap: Record<string, number> = {};
allNotes.forEach(note => {
  const cat = note.data.category || 'Uncategorized';
  categoryMap[cat] = (categoryMap[cat] || 0) + 1;
});
const categories = Object.entries(categoryMap).map(([name, count]) => ({ name, count }));

// 3. Ekstraksi Tag Unik Dinamis
const uniqueTags = new Set<string>();
allNotes.forEach(note => {
  if (Array.isArray(note.data.tags)) {
    note.data.tags.forEach(tag => {
      if (tag.trim() !== '') uniqueTags.add(tag.trim());
    });
  }
});
const tags = Array.from(uniqueTags);
---

<div class="flex flex-col gap-6">
  
  <!-- KARTU PROFIL PENULIS (AXEL KENSHI) -->
  <div class="bg-quilCard border border-zinc-800/60 rounded-2xl p-6 shadow-xl text-center flex flex-col items-center relative overflow-hidden group">
    <!-- Garis Aksen Dekoratif Atas -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-right bg-quilAccent"></div>
    
    <!-- Lingkaran Avatar / Inisial -->
    <div class="w-20 h-20 rounded-2xl bg-zinc-900 border border-zinc-800 overflow-hidden shadow-inner mb-4 group-hover:border-quilAccent transition-colors duration-300 flex items-center justify-center">
      <img 
        src="/assets/nikaidou.jpg" 
        alt="pic" 
        class="w-full h-full object-cover select-none"
        loading="eager"
      />
    </div>
    
    <h2 class="text-zinc-100 font-bold text-lg leading-tight">Axel Kenshi</h2>
    <p class="text-xs text-zinc-500 mt-1 mb-4">IT Student & Full-stack Web/Mobile Dev</p>
    
    <!-- Jembatan Sosial Mini -->
    <div class="flex gap-2">
      <a href="https://github.com" target="_blank" class="p-2 rounded-xl bg-zinc-900 text-zinc-400 border border-zinc-800/60 hover:text-quilAccent hover:border-quilAccent transition-all text-xs flex items-center gap-1.5 font-medium">
        GitHub
      </a>
    </div>
  </div>

  <!-- BLOK STRUKTUR KATEGORI (CATEGORIES) -->
  <div class="bg-quilCard border border-zinc-800/60 rounded-2xl p-5 shadow-xl">
    <h3 class="text-xs font-bold text-zinc-500 tracking-wider uppercase mb-3 flex items-center gap-2">
      <span class="w-1.5 h-3 bg-quilAccent rounded-full inline-block"></span>
      Categories
    </h3>
    <div class="flex flex-col gap-1">
      {categories.length === 0 ? (
        <span class="text-xs text-zinc-600 italic px-2">No categories found</span>
      ) : (
        categories.map((cat) => (
          <a 
            href={`/quil-notes/categories/${cat.name.toLowerCase()}`}
            class="flex items-center justify-between text-xs font-medium text-zinc-400 hover:text-quilText hover:bg-zinc-800/30 px-3 py-2.5 rounded-xl transition-all duration-150"
          >
            <span>{cat.name}</span>
            <span class="px-2 py-0.5 rounded-md bg-zinc-900 text-zinc-500 text-[10px] border border-zinc-800 font-mono group-hover:text-quilAccent">
              {cat.count}
            </span>
          </a>
        ))
      )}
    </div>
  </div>

  <!-- BLOK KAWANAN TAGS (TAG CLOUD) -->
  <div class="bg-quilCard border border-zinc-800/60 rounded-2xl p-5 shadow-xl">
    <h3 class="text-xs font-bold text-zinc-500 tracking-wider uppercase mb-3 flex items-center gap-2">
      <span class="w-1.5 h-3 bg-quilAccent rounded-full inline-block"></span>
      Tags
    </h3>
    <div class="flex flex-wrap gap-2">
      {tags.length === 0 ? (
        <span class="text-xs text-zinc-600 italic">No tags listed</span>
      ) : (
        tags.map((tag) => (
          <a 
            href={`/quil-notes/tags/${tag.toLowerCase()}`}
            class="text-[11px] font-medium text-zinc-400 bg-zinc-900 border border-zinc-800/80 px-2.5 py-1.5 rounded-xl hover:text-quilText hover:border-quilAccent hover:bg-quilAccentMuted transition-all duration-150"
          >
            #{tag}
          </a>
        ))
      )}
    </div>
  </div>

</div>
