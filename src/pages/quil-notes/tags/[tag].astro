---
// src/pages/quil-notes/tags/[tag].astro
import { getCollection } from 'astro:content';
import QuilLayout from '../../../layouts/QuilLayout.astro';

// 1. Ekstrak seluruh variasi tag yang unik untuk dipetakan sebagai rute URL statis
export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  
  // Ambil semua tag, bersihkan string, hilangkan duplikasi
  const allTags = allNotes.flatMap((note) => note.data.tags || []);
  const uniqueTags = [...new Set(allTags)].filter((t) => t.trim() !== '');

  return uniqueTags.map((tag) => {
    // Saring catatan yang memiliki tag ini (case-insensitive)
    const filteredNotes = allNotes.filter((note) =>
      note.data.tags?.some((t: string) => t.toLowerCase() === tag.toLowerCase())
    );

    return {
      params: { tag: tag.toLowerCase() },
      props: { tagName: tag, notes: filteredNotes },
    };
  });
}

const { tagName, notes } = Astro.props;
---

<QuilLayout title={`Tag: #${tagName}`}>
  <div class="space-y-6">
    
    <div class="pb-4 border-b border-zinc-900">
      <h2 class="text-xl font-bold text-zinc-100 flex items-center gap-2">
        <svg class="w-4 h-4 text-quilAccent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 2v4" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 4h-4" />
          <circle cx="4" cy="20" r="2" stroke-width="2" />
        </svg>
        Pinned Tag List: <span class="text-quilText">#{tagName}</span>
      </h2>
      <p class="text-xs text-zinc-500 mt-1">Founded {notes.length} relevant record entries.</p>
    </div>

    <div class="space-y-4">
      {notes.map((note) => (
        <div class="p-5 bg-zinc-900/20 border border-zinc-800/60 rounded-xl hover:border-quilAccent/30 active:border-quilAccent/30 transition-all duration-200 group flex flex-col md:flex-row gap-5 relative overflow-hidden shadow-sm">

          {note.data.img && (
            <div class="w-full md:w-40 h-28 rounded-xl overflow-hidden border border-zinc-900 shrink-0 bg-zinc-950">
              <img 
                src={note.data.img} 
                alt={note.data.title} 
                class="w-full h-full object-cover group-hover:scale-105 group-active:scale-105 transition-transform duration-300 opacity-80 group-hover:opacity-100 group-active:opacity-100" 
              />
            </div>
          )}

          <div class="flex flex-col justify-between flex-grow gap-2">
            
            <div class="space-y-1.5">
              <div class="flex items-center gap-3 text-[10px] font-mono text-zinc-500">
                <time>{new Date(note.data.date).toLocaleDateString('en-EN', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                <span>•</span>
                <span class="text-zinc-400">{note.data.category}</span>
              </div>
              
              <a href={`/quil-notes/${note.id}`} class="block">
                <h3 class="text-base font-bold text-zinc-200 group-hover:text-quilText group-active:text-quilText transition-colors line-clamp-1">
                  {note.data.title}
                </h3>
              </a>
              
              {note.data.description && (
                <p class="text-xs text-zinc-400 font-light line-clamp-2 leading-relaxed pt-0.5">
                  {note.data.description}
                </p>
              )}
            </div>

            <div class="flex flex-wrap gap-1.5 pt-1">
              {note.data.tags.map((t: string) => (
                <a
                  href={`/quil-notes/tags/${t.toLowerCase()}`}
                  class={`text-[9px] font-mono px-2 py-0.5 rounded border transition-all
                    ${t.toLowerCase() === tagName.toLowerCase() 
                      ? 'bg-quilAccentMuted border-quilAccent/40 text-quilText' 
                      : 'bg-zinc-950 border-zinc-900 text-zinc-500 hover:border-quilAccent/20 hover:text-zinc-400 active:text-zinc-400'}`}
                >
                  #{t}
                </a>
              ))}
            </div>

          </div>

        </div>
      ))}
    </div>

  </div>
</QuilLayout>