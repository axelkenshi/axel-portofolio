---
import { getCollection, render } from 'astro:content';
import QuilLayout from '../../layouts/QuilLayout.astro';
import NextPrev from './_components/NextPrev.svelte';

// 1. Definisikan jalur statis untuk seluruh catatan saat build-time
export async function getStaticPaths() {
  const notes = await getCollection('notes');
  
  // Selaraskan urutan dengan halaman feed (Terbaru -> Terlama)
  const sortedNotes = notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sortedNotes.map((note, index) => {
    // Jika indeks > 0, berarti ada artikel yang LEBIH BARU (Previous di dalam feed list)
    const prevNote = index > 0 ? sortedNotes[index - 1] : null;
    
    // Jika indeks < total item, berarti ada artikel yang LEBIH LAMA (Next di dalam feed list)
    const nextNote = index < sortedNotes.length - 1 ? sortedNotes[index + 1] : null;

    return {
      params: { slug: note.id },
      props: { 
        note,
        prevPage: prevNote ? { title: prevNote.data.title, url: `/quil-notes/${prevNote.id}` } : null,
        nextPage: nextNote ? { title: nextNote.data.title, url: `/quil-notes/${nextNote.id}` } : null,
      },
    };
  });
}

const { note, prevPage, nextPage } = Astro.props; // Destructure props navigasi
const { title, date, tags, category, description, img } = note.data;

// 2. Render isi konten Markdown menjadi komponen HTML (<Content />)
const { Content } = await render(note);

// Format tanggal lokal (id-ID)
const formattedDate = new Date(date).toLocaleDateString('en-EN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<QuilLayout title={title}>
  <article class="space-y-6">
    
    <!-- Meta Catatan: Kategori, Tanggal, dan Tags -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-zinc-500 font-mono">
      <span class="px-2 py-0.5 rounded bg-quilAccentMuted text-quilText border border-quilAccent/20">
        {category}
      </span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>

    <!-- Judul Catatan -->
    <h1 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 tracking-tight leading-tight">
      {title}
    </h1>

    <!-- Deskripsi Pendek / Preamble (Jika Ada) -->
    {description && (
      <p class="text-sm text-zinc-400 italic bg-zinc-900/50 border-l-2 border-quilAccent p-3 rounded-r-xl leading-relaxed">
        {description}
      </p>
    )}

    <!-- Gambar Banner Utama (Jika Ada) -->
    {img && (
      <div class="overflow-hidden rounded-2xl border border-zinc-800/80 max-h-[380px] shadow-inner">
        <img src={img} alt={title} class="w-full h-full object-cover transform hover:scale-[1.01] active:scale-[1.01] transition-transform duration-300" />
      </div>
    )}

    <!-- Garis Pembatas Estetik -->
    <hr class="border-zinc-800/60 my-4" />

    <!-- AREA RENDISI MARKDOWN UTAMA (.blog-prose Anda otomatis tersinkron ke warna HSL) -->
    <div class="blog-prose">
      <Content />
    </div>

    <!-- Kaki Artikel: Render Kembali Tag yang Terkait -->
    {tags && tags.length > 0 && (
      <div class="pt-8 border-t border-zinc-900 flex flex-wrap gap-2 items-center">
        <span class="text-xs text-zinc-500 font-mono">Tags:</span>
        {tags.map((tag: string) => (
          <a
            href={`/quil-notes/tags/${tag.toLowerCase()}`}
            class="text-[11px] bg-zinc-900 hover:bg-quilAccentMuted/30 active:bg-quilAccentMuted/30 text-zinc-400 hover:text-quilText active:text-quilText border border-zinc-800/80 hover:border-quilAccent/30 active:border-quilAccent/30 px-2.5 py-1 rounded-md transition-colors font-medium"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Sisipkan Navigasi Statis Tepat di Bagian Paling Bawah Artikel -->
    <NextPrev prevPage={prevPage} nextPage={nextPage} />
  </article>
</QuilLayout>
