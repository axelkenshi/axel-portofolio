---
import { getCollection, render } from 'astro:content';
import QuilLayout from '../../layouts/QuilLayout.astro';

// 1. Definisikan jalur statis untuk seluruh catatan saat build-time
export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.id }, // Menggunakan ID unik file sebagai slug rute URL
    props: { note },
  }));
}

const { note } = Astro.props;
const { title, date, tags, category, description, img } = note.data;

// 2. Render isi konten Markdown menjadi komponen HTML (<Content />)
const { Content } = await render(note);

// Format tanggal lokal (id-ID)
const formattedDate = new Date(date).toLocaleDateString('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<QuilLayout title={title}>
  <article class="space-y-6">
    
    <!-- Meta Catatan: Kategori, Tanggal, dan Tags -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-zinc-500 font-mono">
      <span class="px-2 py-0.5 rounded bg-quilAccentMuted text-quilText border border-quilAccent/20">
        {category}
      </span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>

    <!-- Judul Catatan -->
    <h1 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 tracking-tight leading-tight">
      {title}
    </h1>

    <!-- Deskripsi Pendek / Preamble (Jika Ada) -->
    {description && (
      <p class="text-sm text-zinc-400 italic bg-zinc-900/50 border-l-2 border-quilAccent p-3 rounded-r-xl leading-relaxed">
        {description}
      </p>
    )}

    <!-- Gambar Banner Utama (Jika Ada) -->
    {img && (
      <div class="overflow-hidden rounded-2xl border border-zinc-800/80 max-h-[380px] shadow-inner">
        <img src={img} alt={title} class="w-full h-full object-cover transform hover:scale-[1.01] transition-transform duration-300" />
      </div>
    )}

    <!-- Garis Pembatas Estetik -->
    <hr class="border-zinc-800/60 my-4" />

    <!-- AREA RENDISI MARKDOWN UTAMA (.blog-prose Anda otomatis tersinkron ke warna HSL) -->
    <div class="blog-prose">
      <Content />
    </div>

    <!-- Kaki Artikel: Render Kembali Tag yang Terkait -->
    {tags && tags.length > 0 && (
      <div class="pt-8 border-t border-zinc-900 flex flex-wrap gap-2 items-center">
        <span class="text-xs text-zinc-500 font-mono">Tags:</span>
        {tags.map((tag: string) => (
          <a
            href={`/quil-notes/tags/${tag.toLowerCase()}`}
            class="text-[11px] bg-zinc-900 hover:bg-quilAccentMuted/30 text-zinc-400 hover:text-quilText border border-zinc-800/80 hover:border-quilAccent/30 px-2.5 py-1 rounded-md transition-colors font-medium"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}
  </article>
</QuilLayout>
