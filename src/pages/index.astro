   	<!-- All contents -->
    <!-- Section 1 : BlackHole animation-->
    <HeroCanvas />
    <!-- Section 2 : About Me-->
    <AboutMe />
    <!-- Section 3 : Experience -->
    <Milestone />
    <!-- Section 4 : Certifications -->
    <Certification />
    <!-- Section 5 : Projects -->
    <Projects />
    <!-- Section 6 : Blog Feeds -->
    <BlogFeeds />
    <!-- 7: Footer -->
</Layout>